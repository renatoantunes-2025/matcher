@model List<Property>
@{
    ViewData["Title"] = "Favoritos";
}
<div class="page-head">
    <div>
        <h1>Favoritos</h1>
        <p class="muted">Imóveis salvos para consulta rápida.</p>
    </div>
</div>

<div class="grid property-grid">
    @if (Model.Count == 0)
    {
        <div class="card empty">Nenhum imóvel favoritado ainda. Favorite direto na tela de resultados.</div>
    }
    else
    {
        @foreach (var p in Model)
        {
            <article class="card property-tile">
                <div class="tile-image">
                    <img src="@p.ImageUrl" alt="@p.Title">
                    <form method="post" action="/favoritos/@p.Id/remover" style="position:absolute;right:12px;top:12px">
                        @Html.AntiForgeryToken()
                        <button class="icon-btn favorite active" type="submit">@Html.Raw(Icons.Heart)</button>
                    </form>
                </div>
                <div class="tile-body">
                    <div class="property-kicker">@p.Neighborhood</div>
                    <h3>@p.Title</h3>
                    <div class="property-price">@Helpers.FormatPrice(p.Price)</div>
                    @if (!string.IsNullOrEmpty(p.SourceUrl))
                    {
                        <a class="btn btn-secondary btn-sm" href="@p.SourceUrl" target="_blank">Ver detalhes</a>
                    }
                </div>
            </article>
        }
    }
</div>
